{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(cat *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff*)",
      "Bash(git ls-files*)",
      "Bash(touch /tmp/*)",
      "Bash(cat >> /tmp/*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify-ready.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/catch-dangerous-commands.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/catch-stupid-commands.sh"
          },
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/gws-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/bin/agent_scripts/lint-file.sh \"$CLAUDE_TOOL_INPUT_file_path\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/bin/agent_scripts/lint-file.sh \"$CLAUDE_TOOL_INPUT_file_path\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
