{
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bash /home/cristian/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(cat *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff*)",
      "Bash(git ls-files*)",
      "Bash(touch /tmp/*)",
      "Bash(cat >> /tmp/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hook-pre-tool-use.sh"
          }
        ]
      }
    ]
  }
}
