#!/usr/bin/env bash

PASS=0; FAIL=0; WARN=0

NO_COLOR_FLAG=0; UPDATE_VERSIONS_FLAG=0; HELP_FLAG=0; FAILS_FLAG=0
for _arg in "$@"; do
  case "$_arg" in
    --no-color)        NO_COLOR_FLAG=1 ;;
    --update-versions) UPDATE_VERSIONS_FLAG=1 ;;
    --fails)           FAILS_FLAG=1 ;;
    --help|-h)         HELP_FLAG=1 ;;
  esac
done

if [[ "$HELP_FLAG" -eq 1 ]]; then
  cat <<'EOF'
dotfiles-audit — read-only, non-destructive setup checker for this dotfiles repo.
Verifies required binaries, opt-backed wrappers, guard directories, expected
repos/paths, git submodule state, stow symlink health, Docker, gws-cli config,
optional/WIP mail tools, and version drift against versions.lock.

Usage: dotfiles-audit [--update-versions] [--fails] [--no-color] [--help]
  --update-versions  Rewrite versions.lock from currently installed versions
                     (run on a primary machine to refresh the snapshot).
  --fails            Print only FAIL/WARN lines and the final Summary counts.
                     Suppresses PASS items — use for quick routing decisions.
  --no-color         Disable ANSI colour/dim styling (also honours NO_COLOR).
  --help, -h         Show this message and exit.
EOF
  exit 0
fi

# Color support
if [[ "$NO_COLOR_FLAG" -eq 1 || -n "$NO_COLOR" ]]; then
  C_PASS=""; C_FAIL=""; C_WARN=""; C_BOLD=""; C_DIM=""; C_RESET=""
else
  C_PASS="\033[0;32m"; C_FAIL="\033[0;31m"; C_WARN="\033[0;33m"
  C_BOLD="\033[1m"; C_DIM="\033[2m"; C_RESET="\033[0m"
fi

section() { printf "\n${C_BOLD}=== %s ===${C_RESET}\n" "$1"; }
pass()    { PASS=$((PASS+1)); [[ "$FAILS_FLAG" -eq 1 ]] && return; printf "  ${C_PASS}PASS${C_RESET}  %s\n" "$1"; }
fail()    { printf "  ${C_FAIL}FAIL${C_RESET}  %s\n" "$1"; FAIL=$((FAIL+1)); }
warn()    { printf "  ${C_WARN}WARN${C_RESET}  %s\n" "$1"; WARN=$((WARN+1)); }

check_bin() {
  local cmd="$1" label="${2:-$1}"
  if command -v "$cmd" > /dev/null 2>&1; then pass "$label"; else fail "$label not in PATH (see README.md Installation)"; fi
}

check_bin_warn() {
  local cmd="$1" label="${2:-$1}"
  if command -v "$cmd" > /dev/null 2>&1; then pass "$label"; else warn "$label not in PATH (optional)"; fi
}

check_path() {
  local path="$1" label="${2:-$1}"
  if [[ -e "$path" ]]; then pass "$label"; else fail "$label missing"; fi
}

check_real_dir() {
  local path="$1"
  if [[ -d "$path" && ! -L "$path" ]]; then
    pass "$path is a real directory"
  elif [[ -L "$path" ]]; then
    fail "$path is a symlink (must be a real directory for guard dir; remove it then create: mkdir -p $path)"
  else
    fail "$path missing (create: mkdir -p $path)"
  fi
}

check_wrapper() {
  local cmd="$1" backing="$2" label="${3:-$1}"
  local backing_expanded="${backing/#\~/$HOME}"
  if ! command -v "$cmd" > /dev/null 2>&1; then
    fail "$label wrapper not in PATH"
  elif [[ ! -e "$backing_expanded" ]]; then
    fail "$label wrapper found but backing binary missing ($backing)"
  else
    pass "$label"
  fi
}

_ver_cmd() {
  case "$1" in
    nvim)      echo "nvim --version" ;;
    tmux)      echo "tmux -V" ;;
    git)       echo "git --version" ;;
    zsh)       echo "zsh --version" ;;
    rclone)    echo "rclone --version" ;;
    delta)     echo "delta --version" ;;
    uv)        echo "uv --version" ;;
    fzf)       echo "fzf --version" ;;
    rg)        echo "rg --version" ;;
    alacritty) echo "alacritty --version" ;;
    hx)        echo "hx --version" ;;
    pi)        echo "pi --version" ;;
    rtk)       echo "rtk --version" ;;
    xsv)       echo "xsv --version" ;;
    vd)        echo "vd --version" ;;
    claude)    echo "claude --version" ;;
    go)        echo "go version" ;;
    *)         echo "" ;;
  esac
}

_extract_version() {
  local cmd
  cmd="$(_ver_cmd "$1")"
  [[ -z "$cmd" ]] && return
  eval "$cmd" 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+[a-zA-Z0-9._-]*' | head -1
}

# Compare two version strings numerically. Prints -1 (a<b), 0 (a==b), 1 (a>b).
# Extracts \d+ runs and tuple-compares, tolerant of 3.2a, 0.18.0-dev, etc.
_ver_compare() {
  python3 -c '
import re, sys
def parts(v): return [int(x) for x in re.findall(r"\d+", v)]
a, b = parts(sys.argv[1]), parts(sys.argv[2])
n = max(len(a), len(b))
a += [0] * (n - len(a)); b += [0] * (n - len(b))
print(-1 if a < b else (1 if a > b else 0))
' "$1" "$2" 2>/dev/null
}

VERSION_TOOLS="nvim tmux zsh git rclone delta uv fzf rg alacritty hx pi rtk xsv vd claude go"

# Repo root derived from the script's own real path (bin/ → stow-managed/ → root),
# so the symlinked ~/bin/dotfiles-audit case resolves correctly from any CWD.
# Falls back to ~/Repos/dotfiles if the script was copied out of the repo.
_script_real="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null)"
REPO_ROOT="$(dirname "$(dirname "$(dirname "$_script_real")")")"
[[ -d "$REPO_ROOT/.git" ]] || REPO_ROOT="$HOME/Repos/dotfiles"
LOCK_FILE="$REPO_ROOT/versions.lock"

if [[ "$UPDATE_VERSIONS_FLAG" -eq 1 ]]; then
  printf "# generated by: dotfiles-audit --update-versions\n" > "$LOCK_FILE"
  for _tool in $VERSION_TOOLS; do
    command -v "$_tool" > /dev/null 2>&1 || continue
    _ver=$(_extract_version "$_tool")
    [[ -n "$_ver" ]] && printf "%s=%s\n" "$_tool" "$_ver" >> "$LOCK_FILE"
  done
  echo "Written: $LOCK_FILE"
  exit 0
fi

printf "${C_BOLD}dotfiles-audit${C_RESET} ${C_DIM}— read-only machine setup check; see CLAUDE.md / README.md for remediation steps.${C_RESET}\n"

# ── 1. Required Binaries ─────────────────────────────────────────────────────
section "Required Binaries"
for cmd in zsh tmux git stow rclone docker delta uv claude git-crypt; do
  check_bin "$cmd"
done

# ── 2. Opt-backed Wrappers ───────────────────────────────────────────────────
section "Opt-backed Wrappers"
check_wrapper nvim      ~/opt/nvim
check_wrapper hx        ~/opt/helix/hx
check_wrapper alacritty ~/opt/alacritty
check_wrapper pi        ~/opt/pi/pi
check_wrapper rtk       ~/opt/rtk
check_wrapper fzf       ~/opt/fzf
check_wrapper rg        ~/opt/rg
check_wrapper xsv       ~/opt/xsv
check_wrapper vd        ~/opt/visidata/bin/vd

# go/gofmt share one backing directory; single check covers both
if ! command -v go > /dev/null 2>&1 || ! command -v gofmt > /dev/null 2>&1; then
  fail "go/gofmt wrapper(s) not in PATH"
elif [[ ! -e "$HOME/opt/go/bin/go" ]]; then
  fail "go/gofmt wrappers found but backing binary missing (~/opt/go/bin/go)"
else
  pass "go/gofmt"
fi

# fd special case: wrapper calls /usr/bin/fdfind (Ubuntu package name)
if ! command -v fd > /dev/null 2>&1; then
  fail "fd not in PATH"
elif [[ "$(uname)" == "Darwin" ]]; then
  if [[ ! -e /usr/bin/fdfind ]]; then
    warn "fd wrapper found but /usr/bin/fdfind missing (expected on macOS: brew install fd)"
  else
    pass "fd"
  fi
else
  if [[ ! -e /usr/bin/fdfind ]]; then
    fail "fd wrapper found but /usr/bin/fdfind missing (install: sudo apt install fd-find)"
  else
    pass "fd"
  fi
fi

# ── 3. Guard Directories ─────────────────────────────────────────────────────
section "Guard Directories"
for d in \
  ~/.claude/commands \
  ~/.claude/agents \
  ~/.claude/skills \
  ~/.claude/hooks \
  ~/.pi/agent/extensions \
  ~/.pi/agent/agents
do
  check_real_dir "$d"
done

# ── 4. Expected Repos & Paths ────────────────────────────────────────────────
section "Expected Repos & Paths"
check_path "$REPO_ROOT/.git"         "$REPO_ROOT (git repo)"
check_path ~/opt/pi                  "~/opt/pi"
check_path ~/opt/nvim                "~/opt/nvim"
check_path ~/.nvm/nvm.sh             "~/.nvm (Node version manager)"
check_path ~/.cargo/bin              "~/.cargo/bin (Rust toolchain)"

# ── 5. Git Submodules ────────────────────────────────────────────────────────
section "Git Submodules"
while IFS= read -r line; do
  state="${line:0:1}"
  read -r _ name _ <<< "${line:1}"   # fields: <sha> <path> [(<describe>)]
  case "$state" in
    " ") pass "submodule $name" ;;
    "-") fail "submodule $name not initialized" ;;
    "+") warn "submodule $name is at wrong SHA (run: git submodule update)" ;;
    "U") fail "submodule $name has merge conflict" ;;
    *)   warn "submodule $name unknown state '$state'" ;;
  esac
done < <(git -C "$REPO_ROOT" submodule status 2>/dev/null)

# ── 6. Stow Symlink Health ───────────────────────────────────────────────────
section "Stow Symlink Health"
broken=$(python3 << 'PYEOF'
import os, sys

home = os.path.expanduser("~")
repo = os.path.normpath(os.path.join(home, "Repos/dotfiles/stow-managed"))
skip_dirs = {".cache", "snap", ".git", "Repos"}

for root, dirs, files in os.walk(home, followlinks=False):
    rel = os.path.relpath(root, home)
    top = rel.split(os.sep)[0]
    if top in skip_dirs:
        dirs.clear()
        continue
    dirs[:] = [d for d in dirs if d not in skip_dirs]

    for name in files + dirs:
        full = os.path.join(root, name)
        if not os.path.islink(full):
            continue
        if os.path.exists(full):
            continue
        # broken symlink — check if target resolves into stow-managed
        raw = os.readlink(full)
        target = os.path.normpath(os.path.join(root, raw))
        if target.startswith(repo):
            print(full)
PYEOF
)

if [[ -z "$broken" ]]; then
  pass "no broken stow symlinks"
else
  while IFS= read -r link; do
    fail "broken symlink: $link"
  done <<< "$broken"
fi

# ── 7. Docker ────────────────────────────────────────────────────────────────
section "Docker"
if ! command -v docker > /dev/null 2>&1; then
  fail "docker not in PATH"
else
  pass "docker in PATH"
  if docker info > /dev/null 2>&1; then
    pass "docker daemon reachable"
    container=$(docker ps -a --filter "name=^searxng-websearch$" --format '{{.Names}}' 2>/dev/null)
    if echo "$container" | grep -q "searxng-websearch"; then
      pass "searxng-websearch container exists"
    else
      warn "searxng-websearch container absent (on-demand; run web-search skill to start)"
    fi
  else
    warn "docker daemon unreachable (acceptable on minimal machines)"
  fi
fi

# ── 8. Google Workspace (gws-cli) ────────────────────────────────────────────
section "Google Workspace (gws-cli)"
gws_config="$HOME/.config/gws-cli/gws_config.json"
gws_secret="$HOME/.config/gws-cli/client_secret.json.enc"
gws_token="$HOME/.config/gws-cli/token.json.enc"

if [[ ! -e "$gws_secret" ]]; then
  fail "gws-cli credentials not imported (run: uvx gws-cli@1.3.1 auth import-credentials <client_secret.json>)"
else
  pass "gws-cli client_secret.json.enc present"
fi

if [[ ! -e "$gws_token" ]]; then
  fail "gws-cli token missing (run: uvx gws-cli@1.3.1 auth)"
else
  pass "gws-cli token.json.enc present"
fi

if [[ ! -e "$gws_config" ]]; then
  fail "gws-cli gws_config.json missing"
else
  security_enabled=$(python3 -c "import json; print(json.load(open('$gws_config')).get('security_enabled', True))" 2>/dev/null)
  if [[ "$security_enabled" == "False" ]]; then
    pass "gws-cli security_enabled disabled (prevents fastembed crash on reboot)"
  else
    fail "gws-cli security_enabled is not false — will crash after reboot (run the disable snippet from the google-workspace skill)"
  fi
fi

# ── 9. Agent Script Dependencies ─────────────────────────────────────────────
section "Agent Script Dependencies"
# Playwright chromium (required by webcrawl; script auto-installs on first run)
_playwright_cache="$HOME/.cache/ms-playwright"
if compgen -G "$_playwright_cache/chromium-*" > /dev/null 2>&1; then
  pass "Playwright chromium browsers installed"
else
  warn "Playwright chromium browsers absent — webcrawl will auto-install on first use (~30s), or run: uvx crawl4ai-setup"
fi

# ── 10. Optional / WIP Tools ─────────────────────────────────────────────────
section "Optional / WIP Tools"
check_bin_warn mbsync   "mbsync (mail sync)"
check_bin_warn msmtp    "msmtp (mail send)"
check_bin_warn neomutt  "neomutt (mail client)"

# ── 11. Version Drift ────────────────────────────────────────────────────────
section "Version Drift"
if [[ ! -f "$LOCK_FILE" ]]; then
  warn "no versions.lock found — run: dotfiles-audit --update-versions"
else
  while IFS='=' read -r _tool _locked; do
    [[ -z "$_tool" || "${_tool:0:1}" == "#" ]] && continue
    command -v "$_tool" > /dev/null 2>&1 || continue
    _installed=$(_extract_version "$_tool")
    if [[ -z "$_installed" ]]; then
      warn "$_tool: cannot determine installed version"
    elif [[ "$_installed" == "$_locked" ]]; then
      pass "$_tool $_installed"
    else
      _cmp=$(_ver_compare "$_installed" "$_locked")
      if [[ "$_cmp" == "-1" ]]; then
        warn "$_tool BEHIND  locked=$_locked installed=$_installed"
      elif [[ "$_cmp" == "1" ]]; then
        PASS=$((PASS+1))
        [[ "$FAILS_FLAG" -eq 0 ]] && printf "  ${C_PASS}PASS${C_RESET}  ${C_DIM}%s %s (ahead of lock=%s, ok)${C_RESET}\n" "$_tool" "$_installed" "$_locked"
      else
        # numerically equal but strings differ (e.g. build metadata) — treat as match
        pass "$_tool $_installed"
      fi
    fi
  done < "$LOCK_FILE"
fi

# ── Summary ──────────────────────────────────────────────────────────────────
section "Summary"
printf "  ${C_PASS}PASS${C_RESET}  %d\n" "$PASS"
printf "  ${C_WARN}WARN${C_RESET}  %d\n" "$WARN"
printf "  ${C_FAIL}FAIL${C_RESET}  %d\n" "$FAIL"
echo

[[ "$FAIL" -eq 0 ]]
