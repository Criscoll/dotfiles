#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import os, subprocess, sys

GWS = ["uvx", "gws-cli@1.3.0", "gmail", "download-attachment"]
DEFAULT_OUT_DIR = os.path.expanduser("~/Downloads/gmail-attachments")


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    args = sys.argv[1:]
    out_dir = DEFAULT_OUT_DIR
    positional = []

    i = 0
    while i < len(args):
        if args[i] == "--out-dir" and i + 1 < len(args):
            out_dir = os.path.expanduser(args[i + 1])
            i += 2
        else:
            positional.append(args[i])
            i += 1

    if len(positional) != 3:
        eprint("Usage: gmail-download-attachment <message-id> <attachment-id> <filename> [--out-dir <dir>]")
        sys.exit(2)

    message_id, attachment_id, filename = positional

    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, filename)

    result = subprocess.run(
        GWS + [message_id, attachment_id, out_path],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        eprint(result.stderr.strip())
        sys.exit(result.returncode)

    print(out_path)


if __name__ == "__main__":
    main()
