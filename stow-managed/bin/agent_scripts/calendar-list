#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json
import re
import subprocess
import sys
from datetime import datetime, timezone

GWS = ["uvx", "gws-cli@1.3.0", "calendar", "list"]

DATE_ONLY_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def _local_tz():
    """Return the local timezone as a tzinfo."""
    return datetime.now(timezone.utc).astimezone().tzinfo


def _qualify_date(value: str, is_from: bool) -> str:
    """Convert a date-only string to RFC 3339 with local timezone."""
    dt = datetime.strptime(value, "%Y-%m-%d")
    if is_from:
        dt = dt.replace(hour=0, minute=0, second=0)
    else:
        dt = dt.replace(hour=23, minute=59, second=59)
    return dt.replace(tzinfo=_local_tz()).isoformat()


def main():
    extra = sys.argv[1:]
    show_json = "--json" in extra

    # Convert date-only --from/--to values to full RFC 3339 timestamps
    converted = []
    i = 0
    while i < len(extra):
        arg = extra[i]
        if arg in ("--from", "--to") and i + 1 < len(extra):
            val = extra[i + 1]
            if DATE_ONLY_RE.match(val):
                val = _qualify_date(val, is_from=(arg == "--from"))
            converted.append(arg)
            converted.append(val)
            i += 2
        elif arg.startswith("--from=") or arg.startswith("--to="):
            prefix, val = arg.split("=", 1)
            is_from = prefix == "--from"
            if DATE_ONLY_RE.match(val):
                val = _qualify_date(val, is_from)
            converted.append(f"{prefix}={val}")
            i += 1
        elif arg == "--json":
            i += 1  # wrapper-only flag — strip before forwarding to gws-cli
        else:
            converted.append(arg)
            i += 1

    result = subprocess.run(GWS + converted, capture_output=True, text=True)
    if result.returncode != 0:
        msg = result.stderr.strip()
        if result.stdout:
            try:
                err = json.loads(result.stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        eprint(msg)
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    # Parse events — gws-cli returns events as a JSON-stringified array
    raw_events = outer.get("events")
    if not raw_events:
        print("No events found.")
        return

    if isinstance(raw_events, str):
        try:
            events = json.loads(raw_events)
        except json.JSONDecodeError:
            eprint("Failed to parse events data.")
            sys.exit(1)
    else:
        events = raw_events

    if not events:
        print("No events found.")
        return

    if show_json:
        print(json.dumps(events, indent=2))
        return

    for ev in events:
        summary = ev.get("summary", "(no title)")
        event_id = ev.get("id", "")
        start_str = ev.get("start", "")
        end_str = ev.get("end", "")
        location = ev.get("location", "")

        # Format time range
        if "T" in start_str:
            time_fmt = f"{start_str} -- {end_str}"
        else:
            time_fmt = start_str  # all-day, just show the date

        parts = [time_fmt, summary]
        if location:
            parts.append(location)
        parts.append(event_id)
        print(" | ".join(parts))


if __name__ == "__main__":
    main()
