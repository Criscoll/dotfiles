#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["playwright==1.60.0", "requests==2.32.5"]
# ///
"""Evaluate JavaScript in the active browser tab."""

import argparse
import json
import os
import sys

STATE = os.path.expanduser("~/.cache/browser-scraping/active")


def read_state():
    try:
        return json.load(open(STATE))
    except Exception:
        return {"browser": "chromium", "cdp_url": "http://localhost:9222"}


def format_result(result):
    if isinstance(result, list):
        parts = []
        for item in result:
            if isinstance(item, dict):
                parts.append("\n".join(f"{k}: {v}" for k, v in item.items()))
            else:
                parts.append(str(item))
        print("\n\n".join(parts))
    elif isinstance(result, dict):
        print("\n".join(f"{k}: {v}" for k, v in result.items()))
    elif result is not None:
        print(result)


def eval_firefox(state, code):
    import requests
    base = f"{state['driver_url']}/session/{state['session']}"

    def run(script):
        r = requests.post(f"{base}/execute/sync", json={"script": script, "args": []})
        if r.status_code == 200:
            return True, r.json()["value"]
        return False, r.json().get("value", {}).get("message", r.text)

    # First try as an expression (works for `document.title`, IIFEs, etc.). A
    # SyntaxError here means statements (let/const/multi-line) — and because the
    # parse failed nothing executed, so re-running raw cannot double any side
    # effect. Statement blocks must include their own explicit `return`.
    ok, val = run(f"return ({code})")
    if ok:
        return val
    if "SyntaxError" in str(val):
        ok, val2 = run(code)
        if ok:
            return val2
        val = val2
    print(f"✗ JS error: {val}", file=sys.stderr)
    sys.exit(1)


def eval_chromium(state, code):
    from playwright.sync_api import sync_playwright
    with sync_playwright() as p:
        browser = p.chromium.connect_over_cdp(state["cdp_url"])
        ctx = browser.contexts[0]
        if not ctx.pages:
            print("✗ No active tab", file=sys.stderr)
            sys.exit(1)
        page = ctx.pages[-1]
        # Mirror the Firefox contract: expression first, then fall back to a raw
        # function body (statements ending in an explicit `return`) on SyntaxError.
        try:
            return page.evaluate(f"async () => {{ return ({code}) }}")
        except Exception as e:
            if "SyntaxError" not in str(e):
                raise
            return page.evaluate(f"async () => {{ {code} }}")


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("code", nargs="+", help="JavaScript expression to evaluate")
    args = parser.parse_args()

    code = " ".join(args.code)
    state = read_state()
    if state["browser"] == "firefox":
        result = eval_firefox(state, code)
    else:
        result = eval_chromium(state, code)
    format_result(result)


if __name__ == "__main__":
    main()
