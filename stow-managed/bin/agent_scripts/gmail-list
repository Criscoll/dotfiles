#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json, subprocess, sys

GWS = ["uvx", "gws-cli@1.3.0", "gmail", "list"]


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    extra = sys.argv[1:]
    result = subprocess.run(GWS + extra, capture_output=True, text=True)
    if result.returncode != 0:
        eprint(result.stderr.strip())
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    def extract(wrapped):
        if isinstance(wrapped, dict) and "data" in wrapped:
            return wrapped["data"]
        return wrapped

    data_str = extract(outer.get("messages"))
    if not data_str:
        print("No messages found.")
        return

    try:
        msgs = json.loads(data_str)
    except json.JSONDecodeError:
        eprint("Failed to parse message data.")
        sys.exit(1)

    if not msgs:
        print("No messages found.")
        return

    for m in msgs:
        snippet = m.get("snippet", "").replace("\n", " ").replace("\r", " ")
        print(
            f"{m.get('id','')} | {m.get('date','')} | {m.get('from','')} | "
            f"{m.get('to','')} | {m.get('subject','')} | {snippet}"
        )


if __name__ == "__main__":
    main()