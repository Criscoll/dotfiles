#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["requests==2.32.5"]
# ///
"""Launch a browser for the scraping tools.

Chromium is driven over CDP (remote debugging on :9222). Firefox is driven over
the WebDriver protocol via a geckodriver daemon — a persistent WebDriver session
survives between calls, so the browser stays stateful across the thin browser-*
scripts the same way the Chromium CDP endpoint does.

Both paths write ~/.cache/browser-scraping/active so the client scripts know which
transport to use.
"""

import argparse
import glob
import json
import os
import shutil
import subprocess
import sys
import time

import requests

STATE = os.path.expanduser("~/.cache/browser-scraping/active")


def find_profile(browser):
    if browser == "firefox":
        base = os.path.expanduser("~/.mozilla/firefox/")
        for pattern in ("*.default-release", "*.default"):
            matches = sorted(glob.glob(os.path.join(base, pattern)))
            if matches:
                return matches[0]
    else:
        for path in [
            os.path.expanduser("~/.config/google-chrome"),
            os.path.expanduser("~/.config/chromium"),
        ]:
            if os.path.exists(path):
                return path
    return None


def find_chromium():
    """Locate a Chromium/Chrome binary. Prefer a system install; otherwise fall
    back to Playwright's bundled download (~/.cache/ms-playwright) — the same
    browser crawl4ai/webcrawl uses, so if webcrawl works this will too."""
    binary = (
        shutil.which("chromium-browser")
        or shutil.which("chromium")
        or shutil.which("google-chrome")
    )
    if binary:
        return binary
    cache = os.path.expanduser("~/.cache/ms-playwright")
    matches = sorted(glob.glob(os.path.join(cache, "chromium-*/chrome-linux*/chrome")))
    return matches[-1] if matches else None


def install_playwright_chromium():
    """Download Playwright's bundled Chromium via uvx (one-time, ~180MB).

    `python3 -m playwright install` fails unless the playwright pip package is
    already installed system-wide, which it usually isn't. `uvx --from
    playwright playwright install chromium` runs the installer ephemerally via
    uv instead, so no system install is needed."""
    if not shutil.which("uvx"):
        return False
    print(
        "Chromium not found — installing Playwright's bundled Chromium via uvx "
        "(one-time, ~180MB)...",
        file=sys.stderr,
    )
    result = subprocess.run(["uvx", "--from", "playwright", "playwright", "install", "chromium"])
    return result.returncode == 0


def has_display():
    """Whether an X11/Wayland display is available. On a headless VPS/SSH session
    neither is set, and launching a browser without --headless silently fails to
    open a window, which then never opens its CDP/WebDriver port."""
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))


def find_geckodriver():
    return shutil.which("geckodriver") or (
        os.path.expanduser("~/opt/geckodriver")
        if os.path.exists(os.path.expanduser("~/opt/geckodriver"))
        else None
    )


def write_state(state):
    os.makedirs(os.path.dirname(STATE), exist_ok=True)
    with open(STATE, "w") as f:
        json.dump(state, f)


def wait_for_cdp(port, timeout=30):
    for _ in range(timeout * 2):
        try:
            if requests.get(f"http://localhost:{port}/json/version", timeout=1).ok:
                return True
        except Exception:
            pass
        time.sleep(0.5)
    return False


def wait_for_webdriver(url, timeout=30):
    for _ in range(timeout * 2):
        try:
            if requests.get(f"{url}/status", timeout=1).ok:
                return True
        except Exception:
            pass
        time.sleep(0.5)
    return False


def start_firefox(args):
    driver = find_geckodriver()
    if not driver:
        print(
            "✗ geckodriver not found. Firefox is driven via geckodriver (WebDriver).\n"
            "  Install it once:\n"
            "    curl -sSL https://github.com/mozilla/geckodriver/releases/download/"
            "v0.36.0/geckodriver-v0.36.0-linux64.tar.gz | tar xz -C ~/opt\n"
            "  (or put a geckodriver binary on PATH). Firefox itself must also be installed.",
            file=sys.stderr,
        )
        sys.exit(1)

    url = f"http://localhost:{args.port}"

    # Tear down a previous managed session/daemon. Only touch *our* geckodriver
    # (matched by its port) and its WebDriver session — never the user's own Firefox.
    if os.path.exists(STATE):
        try:
            old = json.load(open(STATE))
            if old.get("browser") == "firefox" and old.get("session"):
                requests.delete(f"{old['driver_url']}/session/{old['session']}", timeout=5)
        except Exception:
            pass
    subprocess.run(["pkill", "-f", f"geckodriver.*--port {args.port}"], capture_output=True)
    time.sleep(1)

    ff_args = []
    if args.profile:
        src = find_profile("firefox")
        if not src:
            print("✗ Could not find firefox profile", file=sys.stderr)
            sys.exit(1)
        cache = os.path.expanduser("~/.cache/browser-scraping/firefox")
        if os.path.exists(cache):
            shutil.rmtree(cache)
        shutil.copytree(src, cache, symlinks=True, ignore_dangling_symlinks=True)
        ff_args = ["-profile", cache]

    headless = not has_display()
    if headless:
        ff_args.append("-headless")

    subprocess.Popen(
        [driver, "--port", str(args.port)],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    if not wait_for_webdriver(url):
        print(f"✗ geckodriver did not become ready on :{args.port}", file=sys.stderr)
        sys.exit(1)

    caps = {"capabilities": {"alwaysMatch": {"moz:firefoxOptions": {"args": ff_args}}}}
    try:
        r = requests.post(f"{url}/session", json=caps, timeout=60).json()
        sid = r["value"]["sessionId"]
    except Exception as e:
        print(f"✗ Failed to create Firefox session: {e}", file=sys.stderr)
        sys.exit(1)

    write_state({"browser": "firefox", "driver_url": url, "session": sid, "port": args.port})
    suffix = " with your profile" if args.profile else ""
    suffix += " (headless, no display detected)" if headless else ""
    print(f"✓ firefox started via geckodriver on :{args.port}{suffix}")


def start_chromium(args):
    subprocess.run(
        ["pkill", "-f", f"remote-debugging-port={args.port}"],
        capture_output=True,
    )
    time.sleep(1)

    cache = os.path.expanduser("~/.cache/browser-scraping/chromium")

    if args.profile:
        src = find_profile("chromium")
        if not src:
            print("✗ Could not find chromium profile", file=sys.stderr)
            sys.exit(1)
        if os.path.exists(cache):
            shutil.rmtree(cache)
        shutil.copytree(src, cache, symlinks=True, ignore_dangling_symlinks=True)
    else:
        os.makedirs(cache, exist_ok=True)

    binary = find_chromium()
    if not binary and install_playwright_chromium():
        binary = find_chromium()
    if not binary:
        print(
            "✗ No Chromium/Chrome binary found, and auto-install didn't produce one.\n"
            "  Install one of:\n"
            "    - a system browser (chromium / google-chrome), or\n"
            "    - Playwright's bundled Chromium:  uvx --from playwright playwright install chromium",
            file=sys.stderr,
        )
        sys.exit(1)
    headless = not has_display()
    cmd = [binary, f"--remote-debugging-port={args.port}", f"--user-data-dir={cache}"]
    if headless:
        cmd.append("--headless=new")

    log_path = os.path.expanduser("~/.cache/browser-scraping/chromium.log")
    no_sandbox = False

    def launch():
        with open(log_path, "w") as log:
            subprocess.Popen(cmd, stdout=log, stderr=subprocess.STDOUT)

    launch()
    ok = wait_for_cdp(args.port)

    if not ok:
        with open(log_path) as f:
            tail = f.read()
        if "No usable sandbox" in tail:
            # Common in containers/CI without unprivileged user namespaces —
            # Chromium's own suggested workaround is --no-sandbox.
            no_sandbox = True
            cmd.append("--no-sandbox")
            launch()
            ok = wait_for_cdp(args.port)

    if ok:
        write_state({"browser": "chromium", "cdp_url": f"http://localhost:{args.port}"})
        suffix = " with your profile" if args.profile else ""
        suffix += " (headless, no display detected)" if headless else ""
        suffix += " (no sandbox — none usable in this environment)" if no_sandbox else ""
        print(f"✓ chromium started on :{args.port}{suffix}")
    else:
        print(f"✗ Failed to connect to chromium on :{args.port}", file=sys.stderr)
        try:
            with open(log_path) as f:
                tail = f.read().strip()
            if tail:
                print(f"  Chromium output ({log_path}):", file=sys.stderr)
                print("  " + tail.replace("\n", "\n  "), file=sys.stderr)
        except OSError:
            pass
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--profile", action="store_true",
                        help="Copy your browser profile (cookies, logins)")
    parser.add_argument("--browser", choices=["firefox", "chromium"], default="chromium")
    parser.add_argument("--port", type=int,
                        help="Debug/driver port (default: 9222 chromium, 4444 firefox)")
    args = parser.parse_args()

    if args.browser == "firefox":
        if args.port is None:
            args.port = 4444
        start_firefox(args)
    else:
        if args.port is None:
            args.port = 9222
        start_chromium(args)


if __name__ == "__main__":
    main()
