#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json, subprocess, sys

GWS = ["uvx", "gws-cli@1.3.0", "gmail", "search"]


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    args = sys.argv[1:]
    query = None
    extra = []

    i = 0
    while i < len(args):
        if args[i] == "--max" and i + 1 < len(args):
            extra += ["--max", args[i + 1]]
            i += 2
        elif query is None:
            query = args[i]
            i += 1
        else:
            extra.append(args[i])
            i += 1

    if not query:
        eprint("Usage: gmail-search [--max N] <query>")
        sys.exit(2)

    result = subprocess.run(GWS + [query] + extra, capture_output=True, text=True)
    if result.returncode != 0:
        eprint(result.stderr.strip())
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    def extract(wrapped):
        if isinstance(wrapped, dict) and "data" in wrapped:
            return wrapped["data"]
        return wrapped

    data_str = extract(outer.get("messages"))
    if not data_str:
        print("No messages found.")
        return

    try:
        msgs = json.loads(data_str)
    except json.JSONDecodeError:
        eprint("Failed to parse message data.")
        sys.exit(1)

    if not msgs:
        print("No messages found.")
        return

    for m in msgs:
        snippet = m.get("snippet", "").replace("\n", " ").replace("\r", " ")
        print(
            f"{m.get('id','')} | {m.get('date','')} | {m.get('from','')} | "
            f"{m.get('to','')} | {m.get('subject','')} | {snippet}"
        )


if __name__ == "__main__":
    main()
