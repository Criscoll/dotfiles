#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["playwright==1.60.0", "requests==2.32.5"]
# ///
"""Navigate the active browser tab to a URL."""

import argparse
import json
import os
import sys

STATE = os.path.expanduser("~/.cache/browser-scraping/active")


def read_state():
    try:
        return json.load(open(STATE))
    except Exception:
        return {"browser": "chromium", "cdp_url": "http://localhost:9222"}


def nav_firefox(state, url, new):
    import requests
    base = f"{state['driver_url']}/session/{state['session']}"
    if new:
        h = requests.post(f"{base}/window/new", json={"type": "tab"}).json()["value"]["handle"]
        requests.post(f"{base}/window", json={"handle": h})
    requests.post(f"{base}/url", json={"url": url})


def nav_chromium(state, url, new):
    from playwright.sync_api import sync_playwright
    with sync_playwright() as p:
        browser = p.chromium.connect_over_cdp(state["cdp_url"])
        ctx = browser.contexts[0]
        if new:
            page = ctx.new_page()
        else:
            page = ctx.pages[-1] if ctx.pages else ctx.new_page()
        page.goto(url, wait_until="domcontentloaded")
        # Exiting the context manager disconnects without closing the browser.


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("url")
    parser.add_argument("--new", action="store_true", help="Open in new tab")
    args = parser.parse_args()

    state = read_state()
    if state["browser"] == "firefox":
        nav_firefox(state, args.url, args.new)
    else:
        nav_chromium(state, args.url, args.new)
    print(f"✓ {'Opened' if args.new else 'Navigated to'}: {args.url}")


if __name__ == "__main__":
    main()
