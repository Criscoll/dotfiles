#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json, re, subprocess, sys

GWS = ["uvx", "gws-cli@1.3.0", "gmail", "read"]


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def clean_text(text: str) -> str:
    text = re.sub(r"<[^>]+>", "", text)
    text = (
        text.replace("&nbsp;", " ")
        .replace("&lt;", "<")
        .replace("&gt;", ">")
        .replace("&amp;", "&")
        .replace("&quot;", '"')
        .replace("&#39;", "'")
    )
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def extract(wrapped):
    if isinstance(wrapped, dict) and "data" in wrapped:
        return wrapped["data"]
    return wrapped


def main():
    args = sys.argv[1:]
    full = False
    limit = 2000
    message_id = None

    i = 0
    while i < len(args):
        if args[i] == "--full":
            full = True
            i += 1
        elif args[i] == "--limit" and i + 1 < len(args):
            limit = int(args[i + 1])
            i += 2
        else:
            message_id = args[i]
            i += 1

    if not message_id:
        eprint("Usage: gmail-read [--full] [--limit N] <message-id>")
        sys.exit(2)

    result = subprocess.run(GWS + [message_id], capture_output=True, text=True)
    if result.returncode != 0:
        msg = result.stderr.strip()
        if result.stdout:
            try:
                err = json.loads(result.stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        eprint(msg)
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    subject = extract(outer.get("subject", ""))
    from_addr = outer.get("from_address", "")
    to_addr = outer.get("to_address", "")
    cc = outer.get("cc", "")
    date = outer.get("date", "")
    labels = outer.get("labels", [])
    body = extract(outer.get("body", ""))

    body_clean = clean_text(body)
    if not full and len(body_clean) > limit:
        body_clean = body_clean[:limit].rstrip() + "\n[…truncated, use --full to show all]"

    attachments = outer.get("attachments", [])

    print(f"From:    {from_addr}")
    print(f"To:      {to_addr}")
    if cc:
        print(f"Cc:      {cc}")
    print(f"Date:    {date}")
    print(f"Labels:  {', '.join(labels)}")
    print(f"Subject: {subject}")
    print("-" * 40)
    print(body_clean if body_clean else "[No body text]")

    if attachments:
        print(f"\nAttachments ({len(attachments)}):")
        for i, att in enumerate(attachments, 1):
            filename = att.get("filename", "(unknown)")
            mime = att.get("mime_type", "")
            size_bytes = att.get("size", 0)
            att_id = att.get("attachment_id", "")
            size_kb = round(size_bytes / 1024, 1)
            print(f"  [{i}] {filename}  {mime}  {size_kb} KB  (attachment_id: {att_id})")


if __name__ == "__main__":
    main()