#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json, subprocess, sys

GWS = ["uvx", "gws-cli@1.3.0", "gmail", "read"]


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def extract(wrapped):
    if isinstance(wrapped, dict) and "data" in wrapped:
        return wrapped["data"]
    return wrapped


def main():
    if len(sys.argv) < 2:
        eprint("Usage: gmail-get-metadata <message-id>")
        sys.exit(2)

    message_id = sys.argv[1]
    result = subprocess.run(GWS + [message_id], capture_output=True, text=True)
    if result.returncode != 0:
        msg = result.stderr.strip()
        if result.stdout:
            try:
                err = json.loads(result.stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        eprint(msg)
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    from_addr = outer.get("from_address", "")
    to_addr = outer.get("to_address", "")
    date = outer.get("date", "")
    labels = outer.get("labels", [])
    subject = extract(outer.get("subject", ""))

    print(f"From:    {from_addr}")
    print(f"To:      {to_addr}")
    print(f"Date:    {date}")
    print(f"Labels:  {', '.join(labels)}")
    print(f"Subject: {subject}")


if __name__ == "__main__":
    main()
