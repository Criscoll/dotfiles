#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["gws-cli==1.3.1"]
# ///

import argparse
import sys

from googleapiclient.errors import HttpError


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    parser = argparse.ArgumentParser(description="Create a recurring calendar event")
    parser.add_argument("summary")
    parser.add_argument("start")
    parser.add_argument("end")
    parser.add_argument("rrule")
    parser.add_argument("--all-day", action="store_true")
    parser.add_argument("--calendar", "-c", default="primary")
    parser.add_argument("--timezone", default="UTC")
    parser.add_argument("--description", "-d", default=None)
    parser.add_argument("--location", "-l", default=None)
    parser.add_argument("--attendees", "-a", default=None)
    args = parser.parse_args()

    from googleapiclient.discovery import build

    from gws.auth.provider import resolve_auth_provider

    auth = resolve_auth_provider()
    service = build("calendar", "v3", credentials=auth.get_credentials())

    if args.all_day:
        start = {"date": args.start}
        end = {"date": args.end}
    else:
        start = {"dateTime": args.start, "timeZone": args.timezone}
        end = {"dateTime": args.end, "timeZone": args.timezone}

    event_body: dict = {
        "summary": args.summary,
        "start": start,
        "end": end,
        "recurrence": [f"RRULE:{args.rrule}"],
    }

    if args.description:
        event_body["description"] = args.description
    if args.location:
        event_body["location"] = args.location
    if args.attendees:
        event_body["attendees"] = [{"email": e.strip()} for e in args.attendees.split(",")]

    try:
        event = service.events().insert(calendarId=args.calendar, body=event_body).execute()
    except HttpError as e:
        eprint(str(e))
        sys.exit(1)

    print(f"Created recurring event: {event['summary']}  (id: {event['id']})")


if __name__ == "__main__":
    main()
