#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

"""
calendar-batch-update: Apply multiple calendar updates concurrently.

Usage:
  calendar-batch-update <updates.json> [--concurrency N] [--calendar <id>]
  calendar-batch-update --help

Input: path to a JSON file containing an array of update objects.
Each object must have "id"; all other fields are optional:

  [
    {"id": "event-id-1", "summary": "New title", "start": "2026-06-28"},
    {"id": "event-id-2", "calendar": "alt-calendar-id", "summary": "- Note"},
    {"id": "event-id-3", "start": "2026-06-28T10:00:00+10:00", "end": "2026-06-28T11:00:00+10:00"}
  ]

Supported per-update fields:
  id          (required) event id
  calendar    calendar id (overrides --calendar for this event)
  summary     new title
  start       new start datetime (ISO 8601)
  end         new end datetime (ISO 8601)
  description new description
  location    new location

Options:
  --calendar <id>  Default calendar for all events (overridable per event)
  --concurrency N  Parallelism limit (default 10)

Runs updates in parallel. Prints one line per event; exits non-zero if any fail.
"""

import asyncio
import json
import sys
from pathlib import Path

GWS = ["uvx", "gws-cli@1.3.1", "calendar", "update"]
DEFAULT_CONCURRENCY = 10

FIELD_FLAGS: dict[str, str] = {
    "summary": "--summary",
    "start": "--start",
    "end": "--end",
    "description": "--description",
    "location": "--location",
}


def eprint(*args: object, **kwargs: object) -> None:
    print(*args, file=sys.stderr, **kwargs)


def _truncate_id(eid: str, max_len: int = 30) -> str:
    """Truncate long event IDs for concise output."""
    if len(eid) <= max_len:
        return eid
    return eid[:12] + "..." + eid[-4:]


async def update_one(semaphore: asyncio.Semaphore, update: dict[str, str], default_cal: str | None) -> dict[str, object]:
    event_id: str = update["id"]
    cmd = GWS + [event_id]
    for field, flag in FIELD_FLAGS.items():
        if field in update:
            cmd += [flag, update[field]]

    # Per-event calendar overrides batch default
    cal = update.get("calendar") or default_cal
    if cal:
        cmd += ["--calendar", cal]

    async with semaphore:
        proc = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
        )
        stdout_b, stderr_b = await proc.communicate()

    stdout = stdout_b.decode().strip()
    stderr = stderr_b.decode().strip()

    if proc.returncode != 0:
        # Mirror the error-parsing logic from calendar-update
        msg = stderr
        if stdout:
            try:
                err = json.loads(stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        return {"id": event_id, "summary": update.get("summary", ""), "ok": False, "error": msg}

    try:
        outer = json.loads(stdout)
        if outer.get("status") == "error":
            return {"id": event_id, "summary": update.get("summary", ""), "ok": False, "error": outer.get("message", "unknown error")}
    except json.JSONDecodeError:
        pass

    return {"id": event_id, "summary": update.get("summary", ""), "ok": True}


async def main() -> None:
    args = sys.argv[1:]

    if not args or "-h" in args or "--help" in args:
        print(__doc__)
        sys.exit(0)

    concurrency = DEFAULT_CONCURRENCY
    path_arg: str | None = None
    default_cal: str | None = None
    i = 0
    while i < len(args):
        if args[i] in ("--concurrency", "-n") and i + 1 < len(args):
            concurrency = int(args[i + 1])
            i += 2
        elif args[i] == "--calendar" and i + 1 < len(args):
            default_cal = args[i + 1]
            i += 2
        else:
            path_arg = args[i]
            i += 1

    if not path_arg:
        eprint("Error: no updates file specified.")
        sys.exit(1)

    updates_path = Path(path_arg)
    if not updates_path.exists():
        eprint(f"Error: file not found: {path_arg}")
        sys.exit(1)

    updates: list[dict[str, str]] = json.loads(updates_path.read_text())
    if not isinstance(updates, list) or not updates:
        eprint("Error: updates file must be a non-empty JSON array.")
        sys.exit(1)

    total = len(updates)
    eprint(f"Processing {total} updates (concurrency={concurrency})...")

    semaphore = asyncio.Semaphore(concurrency)
    tasks = [update_one(semaphore, u, default_cal) for u in updates]
    results: list[dict[str, object]] = await asyncio.gather(*tasks)

    ok = 0
    fail = 0
    for r in results:
        tid = _truncate_id(r["id"])
        summary = r.get("summary", "") or "(no summary change)"
        if r["ok"]:
            ok += 1
            print(f"✓ {tid}  {summary}")
        else:
            fail += 1
            print(f"✗ {tid}  {summary}  [{r['error']}]")

    if fail:
        # Detect common failure patterns
        errors = [r.get("error", "") for r in results if not r["ok"]]
        not_found = sum(1 for e in errors if "Not Found" in e)
        bad_req = sum(1 for e in errors if "Bad Request" in e)
        if not_found > fail // 2:
            eprint("| Hint: most failures are 'Not Found' — events may be on a non-primary calendar. Set --calendar <id> or add 'calendar' field per event in the JSON.")
        elif bad_req > fail // 2:
            eprint("| Hint: most failures are 'Bad Request' — check event IDs and field values.")

    eprint(f"\nDone: {ok}/{total} succeeded" + (f", {fail} failed" if fail else ""))

    if fail:
        sys.exit(1)


asyncio.run(main())
