#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import json
import subprocess
import sys

GWS = ["uvx", "gws-cli@1.3.0", "calendar", "update"]


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    if not sys.argv[1:] or any(a in sys.argv[1:] for a in ("-h", "--help")):
        result = subprocess.run(GWS + ["--help"], capture_output=True, text=True)
        print(result.stdout, end="")
        print(result.stderr, file=sys.stderr, end="")
        sys.exit(result.returncode)

    result = subprocess.run(GWS + sys.argv[1:], capture_output=True, text=True)
    if result.returncode != 0:
        msg = result.stderr.strip()
        if result.stdout:
            try:
                err = json.loads(result.stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        eprint(msg)
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    if outer.get("status") == "error":
        eprint(outer.get("message", "Unknown error"))
        sys.exit(1)

    event_id = outer.get("event_id", "")
    summary = outer.get("summary", "")
    print(f"Updated event: {summary}  (id: {event_id})")


if __name__ == "__main__":
    main()