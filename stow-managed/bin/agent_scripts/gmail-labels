#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///

import argparse, json, subprocess, sys


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def main():
    parser = argparse.ArgumentParser(description="List Gmail labels (token-efficient wrapper)")
    parser.add_argument("--all", action="store_true", help="Include system labels")
    parser.add_argument("--filter", metavar="SUBSTRING", help="Case-insensitive name filter")
    parser.add_argument("--json", action="store_true", dest="json_out", help="Output raw labels array as JSON")
    args = parser.parse_args()

    result = subprocess.run(
        ["uvx", "gws-cli@1.3.0", "gmail", "labels"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        msg = result.stderr.strip()
        if result.stdout:
            try:
                err = json.loads(result.stdout)
                msg = err.get("message", msg) or msg
            except json.JSONDecodeError:
                pass
        eprint(msg)
        sys.exit(result.returncode)

    try:
        outer = json.loads(result.stdout)
    except json.JSONDecodeError:
        eprint("Unexpected non-JSON output:")
        print(result.stdout, end="")
        sys.exit(1)

    labels = outer.get("labels", [])

    if not args.all:
        labels = [l for l in labels if l.get("type") == "user"]

    if args.filter:
        needle = args.filter.lower()
        labels = [l for l in labels if needle in l.get("name", "").lower()]

    if args.json_out:
        print(json.dumps(labels, indent=2))
        return

    if not labels:
        print("No labels found.")
        return

    print("id | name | visibility")
    print("---")
    for l in labels:
        vis = l.get("label_list_visibility") or "-"
        print(f"{l.get('id', '')} | {l.get('name', '')} | {vis}")


if __name__ == "__main__":
    main()
