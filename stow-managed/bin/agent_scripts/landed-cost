#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""Calculate total landed cost in a target currency, handling VAT removal and import tax."""

import argparse
import email.utils
import json
import sys
import urllib.error
import urllib.request

DEFAULT_TARGET = "AUD"
FRANKFURTER_BASE = "https://api.frankfurter.dev/v1"
OPEN_ER_BASE = "https://open.er-api.com/v6/latest"
TIMEOUT = 10
DEFAULT_VAT_PCT = 20.0
HEADERS = {"User-Agent": "curl/8.0"}


def eprint(*args, **kwargs):
    print(*args, file=sys.stderr, **kwargs)


def parse_price_cur(value: str, flag_name: str) -> tuple[float, str]:
    parts = value.rsplit(":", 1)
    if len(parts) != 2:
        eprint(f"Error: {flag_name} must be PRICE:CURRENCY (e.g. 15.98:GBP)")
        sys.exit(2)
    price_str, cur = parts
    try:
        price = float(price_str)
    except ValueError:
        eprint(f"Error: {flag_name} price {price_str!r} is not a number")
        sys.exit(2)
    if price < 0:
        eprint(f"Error: {flag_name} price must be non-negative")
        sys.exit(2)
    return price, cur.upper()


def fetch_rates(target: str, sources: list[str], date: str | None) -> tuple[dict[str, float], str, str]:
    """Fetch rates for source currencies against target in one API call.

    Returns (rates, date_str, source_name) where rates[CUR] = TARGET per 1 CUR.
    Uses base=TARGET so one call covers all sources; inverts the returned rates.
    """
    to_fetch = [s for s in sources if s != target]
    if not to_fetch:
        return {target: 1.0}, "", "none"

    path = f"/{date}" if date else "/latest"
    url = f"{FRANKFURTER_BASE}{path}?base={target}&symbols={','.join(to_fetch)}"
    source_name = "frankfurter"
    date_used = ""
    raw_rates: dict[str, float] = {}

    req = urllib.request.Request(url, headers=HEADERS)
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
            data = json.loads(resp.read())
        raw_rates = data.get("rates", {})
        date_used = data.get("date", date or "")
    except (urllib.error.HTTPError, urllib.error.URLError) as e:
        eprint(f"Frankfurter failed ({e}), trying open.er-api …")
        source_name = "open.er-api"
        req2 = urllib.request.Request(f"{OPEN_ER_BASE}/{target}", headers=HEADERS)
        try:
            with urllib.request.urlopen(req2, timeout=TIMEOUT) as resp2:
                data2 = json.loads(resp2.read())
        except (urllib.error.HTTPError, urllib.error.URLError) as e2:
            eprint(f"open.er-api also failed: {e2}")
            sys.exit(1)
        if data2.get("result") != "success":
            eprint(f"open.er-api error: {data2.get('error-type', 'unknown')}")
            sys.exit(1)
        raw_rates = data2.get("rates", {})
        utc_str = data2.get("time_last_update_utc") or ""
        try:
            dt = email.utils.parsedate_to_datetime(utc_str)
            date_used = dt.strftime("%Y-%m-%d")
        except Exception:
            date_used = utc_str[:10]

    # raw_rates[SRC] = how many SRC per 1 TARGET → invert to get TARGET per 1 SRC
    rates: dict[str, float] = {target: 1.0}
    for s in to_fetch:
        if s not in raw_rates:
            eprint(f"Currency {s!r} not found")
            sys.exit(1)
        rates[s] = 1.0 / raw_rates[s]

    return rates, date_used, source_name


def main():
    parser = argparse.ArgumentParser(
        prog="landed-cost",
        description="Calculate total landed cost in a target currency.",
    )
    parser.add_argument("--item", required=True, metavar="PRICE:CUR",
                        help="Item price and currency (e.g. 15.98:GBP)")
    parser.add_argument("--shipping", metavar="PRICE:CUR", default="0:AUD",
                        help="Shipping cost and currency (default 0:AUD)")

    vat_group = parser.add_mutually_exclusive_group()
    vat_group.add_argument("--ex-vat", action="store_true",
                           help=f"Remove {DEFAULT_VAT_PCT:.0f}%% VAT from item (EU/UK export)")
    vat_group.add_argument("--vat-removed", type=float, metavar="PCT",
                           help="Remove specified %% VAT from item")

    parser.add_argument("--import-tax", type=float, metavar="PCT", default=0.0,
                        help="Import tax %% on (item+shipping) e.g. 10 for AU GST")
    parser.add_argument("--to", metavar="CUR", default=DEFAULT_TARGET,
                        help=f"Target currency (default {DEFAULT_TARGET})")
    parser.add_argument("--date", metavar="YYYY-MM-DD",
                        help="Pin all rates to a historical date")
    args = parser.parse_args()

    item_price, item_cur = parse_price_cur(args.item, "--item")
    shipping_price, shipping_cur = parse_price_cur(args.shipping, "--shipping")
    target = args.to.upper()

    # Determine VAT percentage
    vat_pct = 0.0
    if args.ex_vat:
        vat_pct = DEFAULT_VAT_PCT
    elif args.vat_removed is not None:
        vat_pct = args.vat_removed

    # Collect unique source currencies (skip zero-shipping currency — 0 * any_rate = 0)
    sources_set: set[str] = {item_cur}
    if shipping_price > 0:
        sources_set.add(shipping_cur)
    sources = list(sources_set)

    rates, date_used, source_name = fetch_rates(target, sources, args.date)

    # item: show original price in target; vat_adjustment: negative delta also in target
    item_in_target = round(item_price * rates.get(item_cur, 1.0), 2)
    vat_adj_in_target = 0.0
    if vat_pct > 0:
        price_ex_vat = item_price / (1 + vat_pct / 100)
        vat_adj_in_source = price_ex_vat - item_price  # negative
        vat_adj_in_target = round(vat_adj_in_source * rates.get(item_cur, 1.0), 2)

    shipping_in_target = round(shipping_price * rates.get(shipping_cur, 1.0), 2)

    # Import tax applies to effective item (after VAT) + shipping
    effective_item = item_in_target + vat_adj_in_target
    import_tax_in_target = 0.0
    if args.import_tax > 0:
        import_tax_in_target = round((effective_item + shipping_in_target) * args.import_tax / 100, 2)

    total = round(item_in_target + vat_adj_in_target + shipping_in_target + import_tax_in_target, 2)
    rates_used = {k: round(v, 4) for k, v in rates.items() if k != target}

    print(json.dumps({
        "to": target,
        "date": date_used,
        "source": source_name,
        "breakdown": {
            "item": item_in_target,
            "vat_adjustment": vat_adj_in_target,
            "shipping": shipping_in_target,
            "import_tax": import_tax_in_target,
        },
        "total": total,
        "rates_used": rates_used,
    }, indent=2))


if __name__ == "__main__":
    main()
