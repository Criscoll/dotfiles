# Shell history — never commit
stow-managed/.zsh_history
stow-managed/.bash_history

# Machine-specific Claude Code overrides — never commit
.claude/settings.local.json
stow-managed/.claude/settings.local.json

# Per-machine stow exclusions — never commit
stow-managed/.stow-local-ignore

# Auto-generated fontconfig UUID — never commit
stow-managed/.local/share/fonts/.uuid

# Pi session exports — never commit
pi-session-*.html

# Deep-plan runtime artifacts — never commit
.plans/

# Python bytecode caches — never commit
__pycache__/
**/__pycache__/
